# chrome-extension-release config — read by the Claudinite canon reusable
# workflows (the read-release-config action). REQUIRED and fully explicit: all
# six keys, no defaults. See the pack RELEASE.md for what each means.
manifest_path=extension/manifest.json
package_json_path=package.json
setup_command=npm ci
test_command=npm test
ship_paths=extension
zip_path=dist/google-calendar-event-creator.zip
