# Cached third-party event pages used as test fixtures. They're large
# full-page HTML and skew GitHub's language stats away from the actual
# JavaScript source, so exclude them from Linguist's language detection.
executable-requirements/data/*.html linguist-vendored

# Generated/derived files — regenerated by `npm run regen`, never hand-merged.
# On a merge conflict the `ours` driver keeps one side automatically; you then
# rerun the generator and commit the result, so there's nothing to resolve by
# hand (and the PNGs are binary — they can't be 3-way merged at all). The driver
# is per-clone git config set by .claude/cloud-setup.sh (and the one-time local
# setup in docs/claude/github.md); a clone without it just falls back to
# a normal conflicting merge — still resolvable, only manual. A stale artifact
# can't slip through: its own test fails (the load-order drift guard, the UI
# snapshot pixel diff, the coverage gate). See docs/claude/github.md.
extension/pipeline/load-order.generated.json                        merge=ours
executable-requirements/extractors/fallback/fallback-coverage.baseline.GENERATED.json  merge=ours
executable-requirements/extractors/fallback/fallback-coverage.GENERATED.md             merge=ours
executable-requirements/ui/cases/*.png                                                 merge=ours
