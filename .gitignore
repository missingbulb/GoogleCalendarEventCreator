node_modules/

# Python bytecode cache (e.g. from compiling dev/build/**/*.py)
__pycache__/

# Built extension package (produced by `npm run build` / the Release workflow)
dist/

# UI snapshot test failure artifacts (.actual.png / .diff.png), written here
# by the tests on a mismatch (see dev/requirements/shared/snapshot-artifacts-dir.js).
dev/requirements/shared/.artifacts/

# Stray clone of the Claudinite shared submodule that some environments check
# out at the wrong path (canonical mount is .claudinite/).
docs/

# Claudinite shared-rules canon: fetched over HTTPS into .claudinite/ by
# .claude/hooks/sync-claudinite.sh at session start (Method B; codeload tarball,
# not a git submodule). The synced contents are a vendored artifact, never
# committed -- so ignore everything under .claudinite/ EXCEPT the committed
# .gitkeep marker, which keeps the dir tracked as a one-glance signal that this
# repo mounts Claudinite (see .claudinite/bootstrap.md). The
# /.claudinite/* + !/.claudinite/.gitkeep pair must come in that order so git
# still descends into the dir to re-include the marker; /.claudinite.new/ is the
# hook's swap staging dir.
/.claudinite/*
!/.claudinite/.gitkeep
/.claudinite.new/
